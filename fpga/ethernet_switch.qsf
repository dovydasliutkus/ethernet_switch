set_global_assignment -name FAMILY "Stratix IV"
set_global_assignment -name DEVICE EP4SGX230KF40C2
set_global_assignment -name ORIGINAL_QUARTUS_VERSION 25.1STD.0
set_global_assignment -name PROJECT_CREATION_TIME_DATE "01:55:19  APRIL 20, 2026"
set_global_assignment -name LAST_QUARTUS_VERSION "25.1std.0 Standard Edition"
set_global_assignment -name PROJECT_OUTPUT_DIRECTORY output_files
set_global_assignment -name MIN_CORE_JUNCTION_TEMP 0
set_global_assignment -name MAX_CORE_JUNCTION_TEMP 85
set_global_assignment -name ERROR_CHECK_FREQUENCY_DIVISOR 256
set_global_assignment -name EDA_SIMULATION_TOOL "Questa Altera FPGA (SystemVerilog)"
set_global_assignment -name EDA_TIME_SCALE "1 ps" -section_id eda_simulation
set_global_assignment -name EDA_OUTPUT_DATA_FORMAT "SYSTEMVERILOG HDL" -section_id eda_simulation
set_global_assignment -name EDA_GENERATE_FUNCTIONAL_NETLIST OFF -section_id eda_board_design_timing
set_global_assignment -name EDA_GENERATE_FUNCTIONAL_NETLIST OFF -section_id eda_board_design_symbol
set_global_assignment -name EDA_GENERATE_FUNCTIONAL_NETLIST OFF -section_id eda_board_design_signal_integrity
set_global_assignment -name EDA_GENERATE_FUNCTIONAL_NETLIST OFF -section_id eda_board_design_boundary_scan
set_global_assignment -name PARTITION_NETLIST_TYPE POST_FIT -section_id Top
set_global_assignment -name PARTITION_FITTER_PRESERVATION_LEVEL PLACEMENT_AND_ROUTING -section_id Top
set_global_assignment -name PARTITION_COLOR 16764057 -section_id Top

# --- TOP LEVEL ---
set_global_assignment -name SYSTEMVERILOG_FILE ethernet_switch/rtl/switchcore.sv

# --- MAC LEARNER ---
set_global_assignment -name SYSTEMVERILOG_FILE ethernet_switch/rtl/mac_learner/mac_learner.sv

# --- CROSSBAR ---
set_global_assignment -name SYSTEMVERILOG_FILE ethernet_switch/rtl/crossbar/crossbar_top.sv
set_global_assignment -name SYSTEMVERILOG_FILE ethernet_switch/rtl/crossbar/scheduler/drr_scheduler.sv
set_global_assignment -name SYSTEMVERILOG_FILE ethernet_switch/rtl/crossbar/buffer/voq_buffer_cixb2.sv
set_global_assignment -name VERILOG_FILE ethernet_switch/rtl/crossbar/buffer/fifo.v
set_global_assignment -name QIP_FILE ethernet_switch/rtl/crossbar/FIFOs/pkt_len_fifo.qip

# --- FCS CONTROL ---
set_global_assignment -name SYSTEMVERILOG_FILE ethernet_switch/rtl/fcs_control/fcs_control.sv
set_global_assignment -name SYSTEMVERILOG_FILE ethernet_switch/rtl/fcs_control/output_control.sv
set_global_assignment -name SYSTEMVERILOG_FILE ethernet_switch/rtl/fcs_control/crc_calculator.sv
set_global_assignment -name QIP_FILE ethernet_switch/rtl/fcs_control/FIFOs/data/data_fifo.qip
set_global_assignment -name QIP_FILE ethernet_switch/rtl/fcs_control/FIFOs/dst_mac/dst_mac_fifo.qip
set_global_assignment -name QIP_FILE ethernet_switch/rtl/fcs_control/FIFOs/packet_length/packet_length_fifo.qip
set_global_assignment -name QIP_FILE ethernet_switch/rtl/fcs_control/FIFOs/packet_status/packet_status_fifo.qip
set_global_assignment -name QIP_FILE ethernet_switch/rtl/fcs_control/FIFOs/src_mac/src_mac_fifo.qip

# --- TOP LEVEL ENTITY ---
set_global_assignment -name TOP_LEVEL_ENTITY switchcore
set_global_assignment -name ENABLE_SIGNALTAP ON
set_global_assignment -name USE_SIGNALTAP_FILE crc_debug.stp
